{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rusted",
  "version": "0.1.0",
  "identifier": "com.rusted.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rusted Recorder",
        "width": 400,
        "height": 56,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "shadow": false
      },
      {
        "label": "snip_window",
        "title": "Snip Overlay",
        "fullscreen": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/ffmpeg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
